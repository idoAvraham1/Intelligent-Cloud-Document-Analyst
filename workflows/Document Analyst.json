    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst prompt = `You are a business document intelligence assistant for finance, legal, and procurement teams.\nAnalyze the following business document and return ONLY a valid JSON object with these exact fields.\n\nUse these classification values exactly:\n- invoice\n- contract\n- purchase_order\n- vendor_agreement\n- quote\n- receipt\n- other\n\nFocus on business-relevant details such as parties, dates, amounts, payment terms, PO numbers, contract obligations, and vendor information.\n\nReturn ONLY valid JSON in this shape:\n\n{\n  \"summary\": \"2-3 sentence summary of the document\",\n  \"classification\": \"one of: [invoice, contract, purchase_order, vendor_agreement, quote, receipt, other]\",\n  \"sentiment\": \"one of: [positive, neutral, negative]\",\n  \"entities\": {\n    \"people\": [\"list of person names\"],\n    \"organizations\": [\"list of company or vendor names\"],\n    \"dates\": [\"list of dates mentioned such as invoice date, due date, contract start/end\"],\n    \"amounts\": [\"list of monetary amounts, totals, or payment values\"]\n  },\n  \"action_items\": [\n    \"list of recommended business actions such as approve payment, route to legal, verify PO number, renew contract, or follow up with vendor\"\n  ],\n  \"confidence_score\": 0.0\n}\n\nDocument filename: ${item.filename}\nDocument type: ${item.file_type}\n\nDocument text:\n${item.extracted_text}`;\n\nreturn [{\n  json: {\n    filename: item.filename,\n    file_type: item.file_type,\n    page_count: item.page_count || null,\n    paragraph_count: item.paragraph_count || null,\n    extracted_text: item.extracted_text,\n    prompt: prompt\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -176,
        32
      ],
      "id": "98695c41-79d9-4eb7-8a3b-f48d4697e796",
      "name": "Add prompt"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nfunction cleanText(text) {\n  if (!text) return '';\n\n  return text\n    .replace(/\\r\\n/g, '\\n')\n    .replace(/\\r/g, '\\n')\n    .replace(/(\\w)-\\n(\\w)/g, '$1$2')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .replace(/[ \\t]+/g, ' ')\n    .split('\\n')\n    .map(line => line.trim())\n    .filter(line => line.length > 0)\n    .join('\\n')\n    .slice(0, 30000);\n}\n\nconst cleaned = cleanText(item.extracted_text);\n\nreturn [{\n  json: {\n    filename: item.filename,\n    file_type: item.file_type,\n    page_count: item.page_count || null,\n    paragraph_count: item.paragraph_count || null,\n    extracted_text: cleaned\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
