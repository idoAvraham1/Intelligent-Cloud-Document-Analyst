        "jsCode": "const item = $input.first().json;\n\nconst report = {\n  document_id: item.document_id,\n  filename: item.filename,\n  classification: item.classification,\n  department: item.department,\n  sentiment: item.sentiment,\n  sensitivity: item.sensitivity,\n  routing_tag: item.routing_tag,\n  confidence_score: item.confidence_score,\n  processed_at: item.processed_at,\n  summary: item.summary,\n  action_items: item.action_items,\n  entities: item.entities\n};\n\nconst baseName = item.filename.replace(/\\.[^.]+$/, '');\n\nconst jsonPath = `/data/output_docs/${baseName}_report.json`;\nconst mdPath = `/data/output_docs/${baseName}_report.md`;\n\nconst markdown = `# Document Report: ${item.filename}\n\n- **Document ID:** ${item.document_id}\n- **Classification:** ${item.classification}\n- **Department:** ${item.department}\n- **Sentiment:** ${item.sentiment}\n- **Sensitivity:** ${item.sensitivity}\n- **Routing tag:** ${item.routing_tag}\n\n## Summary\n${item.summary}\n\n## Action items\n${item.action_items}\n`;\n\nconst jsonBuffer = Buffer.from(JSON.stringify(report, null, 2), 'utf8');\nconst mdBuffer = Buffer.from(markdown, 'utf8');\n\nreturn [\n  {\n    json: { ...item, output_path: jsonPath },\n    binary: {\n      data: await this.helpers.prepareBinaryData(\n        jsonBuffer,\n        `${baseName}_report.json`,\n        'application/json'\n      )\n    }\n  },\n  {\n    json: { ...item, output_path: mdPath },\n    binary: {\n      data: await this.helpers.prepareBinaryData(\n        mdBuffer,\n        `${baseName}_report.md`,\n        'text/markdown'\n      )\n    }\n  }\n];"
      },
